# Скопируйте в /opt/ai-web-scout/scout.env и заполните.
#   cp deploy/scout.env.example /opt/ai-web-scout/scout.env

# Ключ OpenAI для движка (keywords + извлечение).
# ВАЖНО: задаётся здесь (env), чтобы переживать перезапуски сервиса.
OPENAI_API_KEY=sk-ЗАМЕНИТЕ

# Пароль на вход (HTTP Basic). Логин по умолчанию: scout
SCOUT_PASSWORD=ЗАМЕНИТЕ_НА_ПАРОЛЬ
SCOUT_USER=scout

# Постоянная БД на диске сервера — переживает перезапуск и хранит всю работу.
SCOUT_DB=/opt/ai-web-scout/scout.db

# Порт локального gunicorn (за nginx). Менять обычно не нужно.
PORT=8000
